<Window x:Class="WinLive.app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WinLive"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Width="{Binding IslandBounds.Width}"
        Height="{Binding IslandBounds.Height}"
        Left="{Binding IslandBounds.Left}"
        Top="{Binding IslandBounds.Top}"
        Visibility="{Binding IsIslandVisible, Converter={StaticResource BoolToVisibilityConverter}}">

    <Border CornerRadius="28"
            Background="#DD111318"
            BorderBrush="#33FFFFFF"
            BorderThickness="1"
            Padding="18"
            MouseLeftButtonDown="Island_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid ColumnDefinitions="*,Auto">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding PrimarySession.Title}"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <Button Content="⏮" Command="{Binding PreviousCommand}" RenderTransformOrigin="-0.19,0.436" Height="23" Width="21" />

                    <TextBlock Text="{Binding PrimarySession.Subtitle}"
                               Foreground="#B8FFFFFF"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis" />

                    <ProgressBar Value="{Binding PrimarySession.Progress, Mode=OneWay}"
                                 Maximum="1"
                                 Height="4"
                                 Margin="0,10,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0">
                    <Button Content="⏭" Command="{Binding NextCommand}" Margin="0,0,6,0" />
                    <Button Content="＋" Command="{Binding ToggleExpandCommand}" />
                </StackPanel>
                <Button Content="⏯" Command="{Binding PlayPauseCommand}" Margin="56,24,8,34" />
            </Grid>

            <ItemsControl Grid.Row="1"
                          ItemsSource="{Binding Sessions}"
                          Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                          Margin="0,14,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8" CornerRadius="12" Background="#22FFFFFF" Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding AppName}" Foreground="#AAFFFFFF" FontSize="12" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</Window>