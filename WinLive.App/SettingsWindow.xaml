<Window x:Class="WinLive.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinLive Settings"
        Width="520"
        Height="470"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="WinLive"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="#12171D" />

        <StackPanel Grid.Row="1" Margin="0,20,0,0">
            <CheckBox Content="Hide during full screen"
                      IsChecked="{Binding HideDuringFullScreen}"
                      Margin="0,0,0,12" />
            <CheckBox Content="Show paused media"
                      IsChecked="{Binding ShowPausedMedia}"
                      Margin="0,0,0,12" />
            <CheckBox Content="Show album art"
                      IsChecked="{Binding ShowAlbumArt}"
                      Margin="0,0,0,12" />
            <Grid ColumnDefinitions="120,*" Margin="0,0,0,12">
                <TextBlock Text="Expand"
                           VerticalAlignment="Center"
                           Foreground="#3F4A56" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <RadioButton Content="Up"
                                 IsChecked="{Binding IsExpansionUp}"
                                 Margin="0,0,18,0" />
                    <RadioButton Content="Down"
                                 IsChecked="{Binding IsExpansionDown}" />
                </StackPanel>
            </Grid>
            <CheckBox Content="Enable localhost API"
                      IsChecked="{Binding ExternalApiEnabled}"
                      Margin="0,8,0,12" />
            <Grid ColumnDefinitions="120,*" Margin="0,0,0,12">
                <TextBlock Text="API address"
                           VerticalAlignment="Center"
                           Foreground="#3F4A56" />
                <TextBox Grid.Column="1"
                         Text="{Binding ApiBaseAddress, Mode=OneWay}"
                         IsReadOnly="True" />
            </Grid>
            <Grid ColumnDefinitions="120,*" Margin="0,0,0,12">
                <TextBlock Text="API port"
                           VerticalAlignment="Center"
                           Foreground="#3F4A56" />
                <TextBox Grid.Column="1"
                         Text="{Binding ApiPort, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
            <Grid ColumnDefinitions="120,*,Auto" Margin="0,0,0,12">
                <TextBlock Text="Token"
                           VerticalAlignment="Center"
                           Foreground="#3F4A56" />
                <TextBox Grid.Column="1"
                         Text="{Binding ApiToken, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True" />
                <Button Grid.Column="2"
                        Content="Regenerate"
                        Command="{Binding RegenerateTokenCommand}"
                        Margin="8,0,0,0"
                        Padding="12,5" />
            </Grid>
            <CheckBox Content="Experimental progress detection"
                      IsChecked="{Binding ExperimentalProgressEnabled}"
                      Margin="0,8,0,12" />
            <Grid ColumnDefinitions="120,*">
                <TextBlock Text="Settings file"
                           VerticalAlignment="Center"
                           Foreground="#3F4A56" />
                <TextBox Grid.Column="1"
                         Text="{Binding SettingsPath, Mode=OneWay}"
                         IsReadOnly="True" />
            </Grid>
            <TextBlock Text="{Binding SettingsStatus}"
                       Foreground="#52606D"
                       Margin="0,16,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Reset position"
                    Command="{Binding ResetPositionCommand}"
                    Padding="12,6"
                    Margin="0,0,8,0" />
            <Button Content="Save"
                    Command="{Binding SaveSettingsCommand}"
                    Padding="18,6"
                    IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
