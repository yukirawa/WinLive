<Window x:Class="WinLive.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinLive 設定"
        Width="580"
        Height="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="WinLive"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="#12171D" />

        <ScrollViewer Grid.Row="1"
                      Margin="0,20,0,0"
                      VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <CheckBox Content="全画面中は非表示"
                      IsChecked="{Binding HideDuringFullScreen}"
                      Margin="0,0,0,12" />
            <CheckBox Content="一時停止中のメディアを表示"
                      IsChecked="{Binding ShowPausedMedia}"
                      Margin="0,0,0,12" />
            <CheckBox Content="アルバムアートを表示"
                      IsChecked="{Binding ShowAlbumArt}"
                      Margin="0,0,0,12" />
            <Grid ColumnDefinitions="120,*" Margin="0,0,0,12">
                <TextBlock Text="島サイズ"
                           VerticalAlignment="Center"
                           Foreground="#3F4A56" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <RadioButton Content="Small"
                                 IsChecked="{Binding IsIslandSizeSmall}"
                                 Margin="0,0,18,0" />
                    <RadioButton Content="Medium"
                                 IsChecked="{Binding IsIslandSizeMedium}"
                                 Margin="0,0,18,0" />
                    <RadioButton Content="Large"
                                 IsChecked="{Binding IsIslandSizeLarge}" />
                </StackPanel>
            </Grid>
            <Grid ColumnDefinitions="120,*" Margin="0,0,0,12">
                <TextBlock Text="展開方向"
                           VerticalAlignment="Center"
                           Foreground="#3F4A56" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <RadioButton Content="上"
                                 IsChecked="{Binding IsExpansionUp}"
                                 Margin="0,0,18,0" />
                    <RadioButton Content="下"
                                 IsChecked="{Binding IsExpansionDown}" />
                </StackPanel>
            </Grid>
            <CheckBox Content="localhost API を有効化"
                      IsChecked="{Binding ExternalApiEnabled}"
                      Margin="0,8,0,12" />
            <Grid ColumnDefinitions="120,*" Margin="0,0,0,12">
                <TextBlock Text="API アドレス"
                           VerticalAlignment="Center"
                           Foreground="#3F4A56" />
                <TextBox Grid.Column="1"
                         Text="{Binding ApiBaseAddress, Mode=OneWay}"
                         IsReadOnly="True" />
            </Grid>
            <Grid ColumnDefinitions="120,*" Margin="0,0,0,12">
                <TextBlock Text="API ポート"
                           VerticalAlignment="Center"
                           Foreground="#3F4A56" />
                <TextBox Grid.Column="1"
                         Text="{Binding ApiPort, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
            <Grid ColumnDefinitions="120,*,Auto" Margin="0,0,0,12">
                <TextBlock Text="トークン"
                           VerticalAlignment="Center"
                           Foreground="#3F4A56" />
                <TextBox Grid.Column="1"
                         Text="{Binding ApiToken, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True" />
                <Button Grid.Column="2"
                        Content="再生成"
                        Command="{Binding RegenerateTokenCommand}"
                        Margin="8,0,0,0"
                        Padding="12,5" />
            </Grid>
            <CheckBox Content="実験的な進行状況検出"
                      IsChecked="{Binding ExperimentalProgressEnabled}"
                      Margin="0,8,0,12" />
            <Grid ColumnDefinitions="120,*" Margin="0,0,0,12">
                <TextBlock Text="デモ activity"
                           VerticalAlignment="Center"
                           Foreground="#3F4A56" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button Content="Download"
                            Command="{Binding StartDemoDownloadCommand}"
                            Padding="10,5"
                            Margin="0,0,8,0" />
                    <Button Content="Encode"
                            Command="{Binding StartDemoEncodeCommand}"
                            Padding="10,5"
                            Margin="0,0,8,0" />
                    <Button Content="Timer"
                            Command="{Binding StartDemoTimerCommand}"
                            Padding="10,5"
                            Margin="0,0,8,0" />
                    <Button Content="停止"
                            Command="{Binding StopDemoActivityCommand}"
                            Padding="10,5" />
                </StackPanel>
            </Grid>
            <Grid ColumnDefinitions="120,*">
                <TextBlock Text="設定ファイル"
                           VerticalAlignment="Center"
                           Foreground="#3F4A56" />
                <TextBox Grid.Column="1"
                         Text="{Binding SettingsPath, Mode=OneWay}"
                         IsReadOnly="True" />
            </Grid>
            <TextBlock Text="{Binding SettingsStatus}"
                       Foreground="#52606D"
                       Margin="0,16,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="位置をリセット"
                    Command="{Binding ResetPositionCommand}"
                    Padding="12,6"
                    Margin="0,0,8,0" />
            <Button Content="保存"
                    Command="{Binding SaveSettingsCommand}"
                    Padding="18,6"
                    IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
