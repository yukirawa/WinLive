<Window x:Class="WinLive.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WinLive"
        d:DesignWidth="374"
        d:DesignHeight="248"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        Left="{Binding WindowLeft, Mode=OneWay, FallbackValue=900}"
        Top="{Binding WindowTop, Mode=OneWay, FallbackValue=680}"
        Width="{Binding WindowWidth, Mode=OneWay, FallbackValue=374, TargetNullValue=374}"
        Height="{Binding WindowHeight, Mode=OneWay, FallbackValue=56, TargetNullValue=56}"
        MinWidth="320"
        MinHeight="50"
        MaxWidth="460"
        MaxHeight="330"
        IsHitTestVisible="{Binding IsIslandVisible, Mode=OneWay, FallbackValue=True}">
    <Window.Resources>
        <Style x:Key="IslandTileStyle" TargetType="Border">
            <Setter Property="Width" Value="{Binding DataContext.WindowWidth, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Setter Property="Height" Value="{Binding DataContext.IslandTileHeight, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Setter Property="Background" Value="#E612171D" />
            <Setter Property="BorderBrush" Value="#36FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{Binding DataContext.IslandTileCornerRadius, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Setter Property="Padding" Value="{Binding DataContext.IslandTilePadding, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="5"
                                      Direction="270"
                                      Opacity="0.34"
                                      Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryTileStyle"
               TargetType="Border"
               BasedOn="{StaticResource IslandTileStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding PrimaryActivity.IsEmphasized}" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="24"
                                              ShadowDepth="5"
                                              Direction="270"
                                              Opacity="0.44"
                                              Color="#4AAFEA" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryTileStyle"
               TargetType="Border"
               BasedOn="{StaticResource IslandTileStyle}">
            <Setter Property="Background" Value="#D9111820" />
        </Style>

        <Style x:Key="SecondaryActivityTileStyle"
               TargetType="Border"
               BasedOn="{StaticResource SecondaryTileStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEmphasized}" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="22"
                                              ShadowDepth="5"
                                              Direction="270"
                                              Opacity="0.4"
                                              Color="#4AAFEA" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActivityIconGlyphStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Foreground" Value="#DFFFFFFF" />
            <Setter Property="FontSize" Value="{Binding DataContext.ActivityGlyphFontSize, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <DataTemplate x:Key="ActivitySummaryTemplate">
            <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                <Grid Width="{Binding DataContext.ActivityIconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                      Height="{Binding DataContext.ActivityIconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                      VerticalAlignment="Center">
                    <Border CornerRadius="{Binding DataContext.ActivityIconCornerRadius, RelativeSource={RelativeSource AncestorType=Window}}"
                            Background="#24FFFFFF"
                            Visibility="{Binding AlbumArtSource, Converter={StaticResource NullToInverseVisibilityConverter}}">
                        <TextBlock Style="{StaticResource ActivityIconGlyphStyle}"
                                   Text="{Binding ActivityIconGlyph}" />
                    </Border>
                    <Border CornerRadius="{Binding DataContext.ActivityIconCornerRadius, RelativeSource={RelativeSource AncestorType=Window}}"
                            ClipToBounds="True"
                            Visibility="{Binding AlbumArtSource, Converter={StaticResource NullToVisibilityConverter}}">
                        <Image Source="{Binding AlbumArtSource}"
                               Stretch="UniformToFill" />
                    </Border>
                </Grid>

                <Grid Grid.Column="1" Margin="9,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding Title}"
                               Foreground="#F7FFFFFF"
                               FontSize="{Binding DataContext.ActivityTitleFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding Subtitle}"
                               Foreground="#B8FFFFFF"
                               FontSize="{Binding DataContext.ActivitySubtitleFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                               Margin="0,1,0,0"
                               TextTrimming="CharacterEllipsis" />
                    <ProgressBar Grid.Row="2"
                                 Value="{Binding Progress, Mode=OneWay}"
                                 Maximum="1"
                                 Margin="0,5,0,0"
                                 Visibility="{Binding Progress, Converter={StaticResource ProgressVisibilityConverter}}" />
                </Grid>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="IslandSurface"
          Width="{Binding WindowWidth, Mode=OneWay, FallbackValue=374, TargetNullValue=374}"
          Height="{Binding WindowHeight, Mode=OneWay, FallbackValue=56, TargetNullValue=56}"
          HorizontalAlignment="Left"
          VerticalAlignment="Top"
          Opacity="0"
          Cursor="SizeAll"
          CacheMode="BitmapCache"
          RenderTransformOrigin="1,1"
          MouseLeftButtonDown="Island_MouseLeftButtonDown"
          MouseMove="Island_MouseMove"
          MouseLeftButtonUp="Island_MouseLeftButtonUp">
        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="IslandScale" ScaleX="0.92" ScaleY="0.92" />
                <TranslateTransform x:Name="IslandTranslate" Y="16" />
            </TransformGroup>
        </Grid.RenderTransform>

        <StackPanel Width="{Binding WindowWidth, Mode=OneWay}">
            <ItemsControl ItemsSource="{Binding SecondaryActivities}"
                          Visibility="{Binding ShowUpSecondaryTiles, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource SecondaryActivityTileStyle}"
                                Margin="0,0,0,8"
                                Tag="{Binding Id}"
                                Opacity="0">
                            <Border.RenderTransform>
                                <TranslateTransform Y="-8" />
                            </Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                             To="0"
                                                             Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>

                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <ContentPresenter Content="{Binding}"
                                                  ContentTemplate="{StaticResource ActivitySummaryTemplate}" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource IconButtonStyle}"
                                        Content="{Binding PlayPauseGlyph}"
                                        Command="{Binding DataContext.PlayPauseActivityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Id}"
                                        ToolTip="Play / pause"
                                        Visibility="{Binding ShowSecondaryPlayPauseControl, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Style="{StaticResource PrimaryTileStyle}">
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <ContentPresenter Content="{Binding PrimaryActivity}"
                                      ContentTemplate="{StaticResource ActivitySummaryTemplate}" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource IconButtonStyle}"
                                Content="&#xE100;"
                                Command="{Binding PreviousCommand}"
                                ToolTip="Previous"
                                Visibility="{Binding ShowPreviousNextControls, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Style="{StaticResource IconButtonStyle}"
                                Content="{Binding PlayPauseGlyph}"
                                Command="{Binding PlayPauseCommand}"
                                ToolTip="Play / pause"
                                Margin="6,0,0,0"
                                Visibility="{Binding ShowMediaTransportControls, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Style="{StaticResource IconButtonStyle}"
                                Content="&#xE101;"
                                Command="{Binding NextCommand}"
                                ToolTip="Next"
                                Margin="6,0,0,0"
                                Visibility="{Binding ShowPreviousNextControls, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Style="{StaticResource IconButtonStyle}"
                                Content="&#xE8A7;"
                                Command="{Binding OpenSourceAppCommand}"
                                ToolTip="Open source"
                                Margin="6,0,0,0"
                                Visibility="{Binding ShowOpenSourceAppControl, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Style="{StaticResource IconButtonStyle}"
                                Content="&#xE711;"
                                Command="{Binding DismissPrimaryCommand}"
                                ToolTip="Dismiss"
                                Margin="6,0,0,0"
                                Visibility="{Binding ShowDismissControl, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Style="{StaticResource IconButtonStyle}"
                                Content="{Binding ExpandGlyph}"
                                Command="{Binding ToggleExpandCommand}"
                                ToolTip="Expand"
                                Margin="6,0,0,0"
                                Visibility="{Binding ShowExpandControl, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>
            </Border>

            <ItemsControl ItemsSource="{Binding SecondaryActivities}"
                          Visibility="{Binding ShowDownSecondaryTiles, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource SecondaryActivityTileStyle}"
                                Margin="0,8,0,0"
                                Tag="{Binding Id}"
                                Opacity="0">
                            <Border.RenderTransform>
                                <TranslateTransform Y="-8" />
                            </Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                             To="0"
                                                             Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>

                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <ContentPresenter Content="{Binding}"
                                                  ContentTemplate="{StaticResource ActivitySummaryTemplate}" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource IconButtonStyle}"
                                        Content="{Binding PlayPauseGlyph}"
                                        Command="{Binding DataContext.PlayPauseActivityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Id}"
                                        ToolTip="Play / pause"
                                        Visibility="{Binding ShowSecondaryPlayPauseControl, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</Window>
